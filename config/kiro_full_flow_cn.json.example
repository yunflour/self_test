{
  "flow": {
    "portalUrl": "https://app.kiro.dev",
    "idp": "BuilderId",
    "startUrl": "https://view.awsapps.com/start",
    "idcRegion": "us-east-1",
    "redirectFrom": "KiroIDE",
    "registerRedirectUri": "http://127.0.0.1/oauth/callback",
    "timeoutSeconds": 600,
    "openBrowser": true,
    "exchangeToken": true,
    "verifyCredential": true,
    "profileArn": "",
    "browser": "camoufox",
    "camoufoxHeadless": "virtual",
    "camoufoxOs": "linux",
    "camoufoxXvfbArgs": "-screen 0 1920x1080x24 -ac -nolisten tcp -dpi 96 +extension RANDR",
    "camoufoxStartupTimeoutSeconds": null,
    "camoufoxAutofillEmail": true,
    "camoufoxAutoBindMfa": true,
    "camoufoxTimings": {
      "clickTargetJitterXMaxPx": 10,
      "clickTargetJitterYMaxPx": 8,
      "clickStartOffsetXMinPx": [-260, -110],
      "clickStartOffsetYMinPx": [-140, 140],
      "clickPathSteps": [6, 11],
      "clickPathJitterXMaxPx": [-2, 2],
      "clickPathJitterYMaxPx": [-2, 2],
      "clickStartPauseMs": [220, 650],
      "clickStepPauseMs": [90, 240],
      "clickBeforeDownPauseMs": [180, 500],
      "clickHoldPauseMs": [110, 260],
      "selectorPollPauseMs": 300,
      "mfaCodeTypeDelayMs": [55, 120],
      "mfaCodePostTypePauseMs": [700, 1800],
      "mfaSecurityPageSettlePauseMs": 3200,
      "mfaRegisterPostClickPauseMs": 1800,
      "mfaSeedPollPauseMs": 300,
      "mfaAssignPostClickPauseMs": 5200,
      "emailPageSettlePauseMs": [4500, 9000],
      "emailTypeDelayMs": [75, 150],
      "emailPostTypePauseMs": [1400, 3200],
      "continuePreClickPauseMs": [1400, 3200],
      "continuePostClickPauseMs": [1200, 2800],
      "continueStatePollPauseMs": 1200,
      "nameTypeDelayMs": [70, 140],
      "namePreClickPauseMs": [1200, 2600],
      "nameRetryPauseMs": 2600,
      "nameEnterPostPauseMs": 1300,
      "verifyCodeTypeDelayMs": [55, 120],
      "verifyCodePostTypePauseMs": [900, 2200],
      "verifyCodeSubmitPostPauseMs": 3200,
      "passwordTypeDelayMs": [55, 120],
      "passwordConfirmTypeDelayMs": [55, 120],
      "passwordPreClickPauseMs": [900, 1800],
      "passwordSubmitPostPauseMs": 3200,
      "allowAccessPreClickPauseMs": [700, 1800]
    },
    "saveResult": true,
    "outputJson": false,
    "callbackPort": null,
    "skipSecondStage": false
  },
  "callbackPorts": [
    3128,
    4649,
    6588,
    8008,
    9091,
    49153,
    50153,
    51153,
    52153,
    53153
