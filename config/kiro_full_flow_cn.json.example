{
  "flow": {
    "portalUrl": "https://app.kiro.dev",
    "idp": "BuilderId",
    "startUrl": "https://view.awsapps.com/start",
    "idcRegion": "us-east-1",
    "redirectFrom": "KiroIDE",
    "registerRedirectUri": "http://127.0.0.1/oauth/callback",
    "timeoutSeconds": 600,
    "openBrowser": true,
    "exchangeToken": true,
    "verifyCredential": true,
    "profileArn": "",
    "browser": "camoufox",
    "camoufoxHeadless": false,
    "camoufoxOs": "auto",
    "camoufoxStartupTimeoutSeconds": null,
    "camoufoxAutofillEmail": true,
    "saveResult": true,
    "outputJson": false,
    "callbackPort": null,
    "skipSecondStage": false
  },
  "callbackPorts": [
    3128,
    4649,
    6588,
    8008,
    9091,
    49153,
    50153,
    51153,
    52153,
    53153
  ],
  "initiateLoginPath": "/service/KiroWebPortalService/operation/InitiateLogin",
  "kiroGrantScopes": [
    "codewhisperer:completions",
    "codewhisperer:analysis",
    "codewhisperer:conversations",
    "codewhisperer:transformations",
    "codewhisperer:taskassist"
