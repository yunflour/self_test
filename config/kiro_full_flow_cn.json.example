    "baseUrl": "https://temp-mail.xxxxx.workers.dev", //邮箱服务器域名
    "origin": "https://xxxxx.xxxxx.workers.dev",
    "bootstrapToken": "Toekn", //邮箱Token
    "domain": "xxxx.com", //域名
    "fingerprint": "299edca5955a3aec40b45fda12778cc9", //固定就行 无所谓
